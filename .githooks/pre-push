#!/bin/bash

# Pre-push hook: Prevents pushing to wrong remotes
# - main branch can ONLY be pushed to 'origin' (Commercial repo)
# - public-release branch can ONLY be pushed to 'public' (Community repo)

remote="$1"
url="$2"

while read local_ref local_sha remote_ref remote_sha; do
    branch=$(echo "$local_ref" | sed 's|refs/heads/||')
    
    if [ "$branch" = "main" ] && [ "$remote" != "origin" ]; then
        echo ""
        echo "ERROR: Cannot push 'main' branch to '$remote'"
        echo "       The 'main' branch can only be pushed to 'origin' (Commercial repo)"
        echo ""
        echo "If you meant to push to Commercial: git push origin main"
        echo ""
        exit 1
    fi
    
    if [ "$branch" = "public-release" ] && [ "$remote" != "public" ]; then
        echo ""
        echo "ERROR: Cannot push 'public-release' branch to '$remote'"
        echo "       The 'public-release' branch can only be pushed to 'public' (Community repo)"
        echo ""
        echo "If you meant to push to Community: git push public public-release"
        echo ""
        exit 1
    fi
done

exit 0
